{
  "name": "raydium-cpmm-arbitrage-monitor",
  "version": "1.0.0",
  "description": "Real-time arbitrage monitoring tool for Raydium CPMM pools on Solana. Detects price discrepancies across pools for a given token pair and signals profitable arbitrage opportunities.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "solana",
    "raydium",
    "cpmm",
    "arbitrage",
    "defi",
    "monitoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.95.5",
    "axios": "^1.7.9",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
