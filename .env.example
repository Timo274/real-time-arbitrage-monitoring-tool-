# ============================================================
# Raydium CPMM Arbitrage Monitor — Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# ============================================================

# Solana RPC endpoint.
# Use a private RPC for production (Helius, QuickNode, Triton, etc.)
# Public endpoints are rate-limited and unreliable for real-time monitoring.
# This endpoint is ONLY used when USE_ONCHAIN_RESERVES=true.
RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Whether to refresh pool reserves directly from on-chain vault accounts
# every tick. When false, reserves are taken from the Raydium HTTP API
# (which can be cached and lag chain state by minutes). Strongly
# recommended to enable with a private RPC for true real-time monitoring.
USE_ONCHAIN_RESERVES=false

# Polling interval in milliseconds.
# How often the tool fetches fresh pool data.
# Recommended: 3000–10000ms depending on your RPC plan.
POLL_INTERVAL_MS=5000

# Minimum net profit threshold (in USD) to flag an arbitrage opportunity
# as "actionable". Set to 0 to flag every positive-profit opportunity.
MIN_PROFIT_THRESHOLD_USD=0.50

# Minimum pool TVL (USD) for a pool to be considered for arbitrage.
# Pools below this are still discovered and shown in the pool table,
# but excluded from arbitrage detection (avoids noise from dust pools).
MIN_POOL_TVL_USD=1000

# Whether to also include legacy AMM v4 ("Standard") pools alongside
# CPMM pools. Off by default to keep results focused on CPMM (per spec).
INCLUDE_AMM_V4=false

# Assumed Solana transaction cost in SOL.
# A typical swap tx costs ~0.000005 SOL in base fees + priority fees.
# Adjust upward if you plan to use priority fees for faster inclusion.
SOL_TX_FEE_ESTIMATE=0.00035

# Current SOL price in USD (used to convert tx fees to USD).
# Update this periodically or integrate a price oracle for accuracy.
SOL_PRICE_USD=150.00

# Trade size in USD for profit estimation.
# The tool calculates potential profit based on this notional trade size,
# using the actual CPMM swap formula (so slippage is priced in).
TRADE_SIZE_USD=1000.00

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
